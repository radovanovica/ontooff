# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
DATABASE_URL="postgresql://postgres:root@localhost:5432/activity_tracking"

# ─────────────────────────────────────────
# NextAuth
# ─────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars-here"

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─────────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="ontooff <no-reply@yourdomain.com>"

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ontooff"

# ─────────────────────────────────────────
# AWS S3 (image storage)
# ─────────────────────────────────────────
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_REGION="eu-north-1"
AWS_S3_BUCKET="amzn-s3-ontooff-bucket"
